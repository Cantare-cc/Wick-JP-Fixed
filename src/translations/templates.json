{
  "$description": "案 B: 反復パターンと、サーバーごとに変動する数値を吸収するテンプレート。先頭から順にマッチを試す。",
  "patterns": [
    {
      "id": "role_needs_permissions",
      "pattern": "^(.+) needs some permissions added\\.$",
      "replace": "{1} に追加すべき権限があります。"
    },
    {
      "id": "role_perms_to_remove",
      "pattern": "^(.+) has some permissions that need to be removed\\.$",
      "replace": "{1} から外すべき権限があります。"
    },
    {
      "id": "wick_cant_monitor_roles",
      "pattern": "^Wick can't monitor (\\d+) roles?\\. Anyone with these roles is 100% immune and safe from Wick\\.$",
      "replace": "Wick が {1} 個のロールを監視できません。これらのロールを持つメンバーは Wick の影響を完全に受けません。"
    },
    {
      "id": "you_have_n_native_kick_ban",
      "pattern": "^You have (\\d+) roles? that can natively Kick/Ban\\. You should remove the native moderation permissions from these roles and force your staff to instead use Wick's moderation commands that are supervised by Wick's anti nuke:$",
      "replace": "Discord 標準のキック・BAN 権限を持つロールが {1} 個あります。これらのロールから標準のモデレーション権限を外し、スタッフには Wick の Nuke 対策で監視されるモデレーションコマンドを使わせてください:"
    },
    {
      "id": "n_issues",
      "pattern": "^(\\d+) issues?$",
      "replace": "{1} 件の問題"
    },
    {
      "id": "n_minutes",
      "pattern": "^(\\d+) minutes?$",
      "replace": "{1} 分"
    },
    {
      "id": "n_seconds",
      "pattern": "^(\\d+) seconds?$",
      "replace": "{1} 秒"
    },
    {
      "id": "n_days",
      "pattern": "^(\\d+) days?$",
      "replace": "{1} 日"
    },
    {
      "id": "n_hours",
      "pattern": "^(\\d+) hours?$",
      "replace": "{1} 時間"
    },
    {
      "id": "n_members",
      "pattern": "^(\\d+) members?$",
      "replace": "{1} 人"
    },
    {
      "id": "n_servers",
      "pattern": "^(\\d+) servers?$",
      "replace": "{1} サーバー"
    },
    {
      "id": "moment_n_seconds_ago",
      "pattern": "^(\\d+) seconds? ago$",
      "replace": "{1} 秒前"
    },
    {
      "id": "moment_n_minutes_ago",
      "pattern": "^(\\d+) minutes? ago$",
      "replace": "{1} 分前"
    },
    {
      "id": "moment_n_hours_ago",
      "pattern": "^(\\d+) hours? ago$",
      "replace": "{1} 時間前"
    },
    {
      "id": "moment_n_days_ago",
      "pattern": "^(\\d+) days? ago$",
      "replace": "{1} 日前"
    },
    {
      "id": "moment_n_months_ago",
      "pattern": "^(\\d+) months? ago$",
      "replace": "{1} か月前"
    },
    {
      "id": "moment_n_years_ago",
      "pattern": "^(\\d+) years? ago$",
      "replace": "{1} 年前"
    },
    {
      "id": "moment_in_n_minutes",
      "pattern": "^in (\\d+) minutes?$",
      "replace": "{1} 分後"
    },
    {
      "id": "moment_in_n_hours",
      "pattern": "^in (\\d+) hours?$",
      "replace": "{1} 時間後"
    },
    {
      "id": "moment_in_n_days",
      "pattern": "^in (\\d+) days?$",
      "replace": "{1} 日後"
    },
    {
      "id": "moment_a_few_seconds_ago",
      "pattern": "^a few seconds ago$",
      "replace": "数秒前"
    },
    {
      "id": "moment_a_minute_ago",
      "pattern": "^a minute ago$",
      "replace": "1 分前"
    },
    {
      "id": "moment_an_hour_ago",
      "pattern": "^an hour ago$",
      "replace": "1 時間前"
    },
    {
      "id": "moment_a_day_ago",
      "pattern": "^a day ago$",
      "replace": "1 日前"
    },
    {
      "id": "moment_a_month_ago",
      "pattern": "^a month ago$",
      "replace": "1 か月前"
    },
    {
      "id": "moment_a_year_ago",
      "pattern": "^a year ago$",
      "replace": "1 年前"
    },
    {
      "id": "today_at_hhmm_ampm",
      "pattern": "^Today at (\\d{1,2}):(\\d{2}) (AM|PM)$",
      "replace": "本日 {1}:{2} {3}"
    },
    {
      "id": "today_at_hhmm",
      "pattern": "^Today at (\\d{1,2}:\\d{2})$",
      "replace": "本日 {1}"
    },
    {
      "id": "yesterday_at_hhmm",
      "pattern": "^Yesterday at (\\d{1,2}:\\d{2})$",
      "replace": "昨日 {1}"
    },
    {
      "id": "silenced_for",
      "pattern": "^(.+) has been silenced for (.+)!$",
      "replace": "{1} を {2} ミュートにしました！"
    },
    {
      "id": "has_been_warned",
      "pattern": "^(.+) has been warned!$",
      "replace": "{1} に警告しました！"
    },
    {
      "id": "has_been_kicked",
      "pattern": "^(.+) has been kicked!$",
      "replace": "{1} をキックしました！"
    },
    {
      "id": "has_been_banned",
      "pattern": "^(.+) has been banned!$",
      "replace": "{1} を BAN しました！"
    },
    {
      "id": "has_been_timed_out",
      "pattern": "^(.+) has been timed out!$",
      "replace": "{1} をタイムアウトしました！"
    },
    {
      "id": "x_banned_y",
      "pattern": "^(.+) banned(.+)$",
      "replace": "{1} さんが {2} を BAN しました"
    },
    {
      "id": "x_kicked_y",
      "pattern": "^(.+) kicked(.+)$",
      "replace": "{1} さんが {2} をキックしました"
    },
    {
      "id": "x_quarantined_y",
      "pattern": "^(.+) quarantined(.+)$",
      "replace": "{1} さんが {2} を隔離しました"
    },
    {
      "id": "x_members",
      "pattern": "^(\\d{1,3}(?:,\\d{3})+) (members|メンバー)$",
      "replace": "{1} 人"
    },
    {
      "id": "use_X_module",
      "pattern": "^Use the (.+) module\\.$",
      "replace": "{1} 機能を有効にする。"
    },
    {
      "id": "use_X",
      "pattern": "^Use the (.+)\\.$",
      "replace": "{1} を有効にする。"
    },
    {
      "id": "target_accounts_X",
      "pattern": "^Target accounts (.+)\\.$",
      "replace": "{1} アカウントを対象にする。"
    }
  ]
}
